.env
.env.*
!.env.example

# ==========================================
# 2. Python (FastAPI, Django, Celery)
# ==========================================
# Cache i skompilowane pliki
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Wirtualne środowiska (jeśli ktoś uruchomi lokalnie zamiast w Dockerze)
venv/
.venv/
env/
.env_python/

# Pliki Django i Celery
db.sqlite3
db.sqlite3-journal
celerybeat-schedule
celerybeat.pid
*.log

# Poetry
# (Nie ignorujemy poetry.lock - powinien być w repozytorium!)

# ==========================================
# 3. Node.js (React Web, React Native, Expo)
# ==========================================
node_modules/
dist/
dist-ssr/
build/
.expo/
.next/
*.tsbuildinfo

# Logi NPM/Yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# (Nie ignorujemy package-lock.json - powinien być w repozytorium!)

# ==========================================
# 4. Java (Spring Boot - przygotowanie)
# ==========================================
target/
*.class
*.jar
*.war
.mvn/
!/.mvn/wrapper/maven-wrapper.jar

